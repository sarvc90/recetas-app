# Copy to recetas.env (gitignored) and fill in real values.
# Local dev: keep this file at recetas-app/recetas.env (loaded by spring.config.import).
# Prod EC2: same file lives at /opt/recetas/recetas.env and is mounted via docker-compose env_file.

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Spring JPA Hibernate DDL auto
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=recetas_app
DB_USER=
DB_PASS=

# CORS (prod only)
CORS_ALLOWED_ORIGINS=https://rincon-sabores.online,https://www.rincon-sabores.online
CORS_ALLOWED_ORIGIN_PATTERNS=

# JVM
JAVA_OPTS=-Xms256m -Xmx512m

# SMTP
SMTP_USERNAME=
SMTP_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT (>=64 chars random)
JWT_SECRET=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Grafana (read by compose env_file -> grafana container picks them up natively)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
